exports[`create > snapshots generated Node.js scaffold output 1`] = `
{
  ".dockerignore": ".git
",
  ".gitignore": "dist
node_modules
.env
",
  "Dockerfile": "FROM node:24-slim AS base
WORKDIR /app

FROM base AS package-manager
RUN corepack enable pnpm && corepack install -g pnpm@9.0.0 

FROM package-manager AS dev
COPY package.json pnpm-lock.yaml ./
RUN pnpm install
COPY src/ ./src/
CMD ["pnpm"]
",
  "Procfile": "web: node dist/index.js
",
  "README.md": "# snapshot-node-app

Generated by Universe CLI.
",
  "compose.yaml": "services:
  app:
    build:
      context: ./
      target: dev
    develop:
      watch:
        - action: sync
          path: ./src
          target: /app/src
        - action: rebuild
          path: ./package.json
        - action: rebuild
          path: ./pnpm-lock.yaml
    ports:
      - 3000:3000
",
  "package.json": "{
  "name": "snapshot-node-app",
  "private": true,
  "type": "module"
}
",
  "platform.yaml": "site: snapshot-node-app
",
  "src/index.ts": "console.log('hello');
",
}
`;

